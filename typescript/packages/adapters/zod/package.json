{
	"name": "@vectorfyco/valbridge-zod",
	"version": "0.3.0",
	"type": "module",
	"description": "Render valbridge IR into Zod schemas",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"bin": {
		"valbridge-zod": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"test": "pnpm exec vitest run",
		"typecheck": "tsc --noEmit",
		"compliance": "ADAPTER=$PWD && cd ../../../../cli && go run . compliance --dev-report --adapter-path $ADAPTER",
		"type-fidelity": "pnpm exec tsx type-probe/type-fidelity.ts"
	},
	"dependencies": {
		"@vectorfyco/valbridge-core": "workspace:*"
	},
	"devDependencies": {
		"zod": "^4.3.6"
	},
	"peerDependencies": {
		"zod": "^3.25.0 || ^4.0.0"
	}
}
